# =============================================================================
# cpf-ssp-agent-frontend — server-only configuration
#
# Copy to `.env.local` and fill in. NONE of these use the NEXT_PUBLIC_ prefix:
# every value below stays on the server. The browser only ever talks to this
# app's own /api/agent route, never to the agent or AWS directly.
# =============================================================================

# --- which transport the server adapter uses to reach the agent ---
#   "http" -> POST the JSON payload to a plain HTTP endpoint (local dev default)
#   "aws"  -> SigV4-signed Bedrock AgentCore InvokeAgentRuntime
AGENT_MODE=http

# --- Mode B: plain HTTP -------------------------------------------------------
# Full invocations URL. For a local `agentcore dev` the app serves POST /invocations.
AGENT_HTTP_URL=http://localhost:8080/invocations
# The local `agentcore dev` server requires an "X-Agentcore-Local: true" header.
# It is sent by default in http mode. Set to "false" only when fronting the
# runtime with an API Gateway/ALB that rejects unexpected headers.
AGENT_HTTP_LOCAL_HEADER=true

# --- Mode A: deployed AWS AgentCore runtime ----------------------------------
# Required when AGENT_MODE=aws.
AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:ap-southeast-1:<ACCOUNT_ID>:runtime/<name>
AWS_REGION=ap-southeast-1
# AWS credentials are read from the standard AWS chain on the server:
#   AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_SESSION_TOKEN, SSO, or an
#   attached IAM role. Do NOT hardcode them here in committed files.

# Note: this app does NOT use a server-side AZDO_PAT fallback. The PAT is always
# supplied per-request by the user via the form's required PAT field.
